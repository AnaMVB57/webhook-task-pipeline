# Variables for VS Code REST Client
@ldelim = {{
@rdelim = }}
@host = http://localhost:3000

### Health check
GET {{host}}/health


# ──────────────────────────────────────────────────────────────────────────────
# ─── USERS ────────────────────────────────────────────────────────────────────
# ──────────────────────────────────────────────────────────────────────────────

### Create user
POST {{host}}/api/users
Content-Type: application/json

{
  "name": "Ana García",
  "email": "ana@example.com"
}

### Get all users
GET {{host}}/api/users

### Get user by id
GET {{host}}/api/users/9c83aeee-4f10-4538-a55a-b7053b7bf0a2

### Edit user
PUT {{host}}/api/users/9c83aeee-4f10-4538-a55a-b7053b7bf0a2
Content-Type: application/json

{
  "name": "Ana García Rodríguez",
  "email": "ana@example.com"
}

### Delete user by id
DELETE {{host}}/api/users/46dd8d78-f82f-4159-8674-6685c48b969c


# ──────────────────────────────────────────────────────────────────────────────
# ─── ACTIONS ──────────────────────────────────────────────────────────────────
# ──────────────────────────────────────────────────────────────────────────────

### Get all actions
GET {{host}}/api/actions

### Get action by id
GET {{host}}/api/actions/73619324-2e47-4570-9787-489f172bdba3

### Action 1: CALCULATE_TOTAL
POST {{host}}/api/actions
Content-Type: application/json

{
  "name": "CALCULATE_TOTAL",
  "description": "Sums numeric values from an array field in the payload",
  "config": { "arrayField": "items", "priceField": "price", "quantityField": "quantity" }
}

### Action 2: TEXT_TEMPLATER
POST {{host}}/api/actions
Content-Type: application/json

{
  "name": "TEXT_TEMPLATER",
  "description": "Fills a text template with payload values",
  "config": { "template": "¡Hola {{ldelim}}customer{{rdelim}}!\n\nGracias por elegir {{ldelim}}store_name{{rdelim}}. Este es un resumen de tu compra realizada el {{ldelim}}date{{rdelim}}:\n\n{{ldelim}}items{{rdelim}}\n\nSubtotal: ${{ldelim}}subtotal{{rdelim}}\nTotal Pagado: ${{ldelim}}total_amount{{rdelim}}\n\nEstado actual de tu pedido: {{ldelim}}status{{rdelim}}\n\n¡Esperamos verte pronto!" }
}

### Action 3: TRANSLATE_TEXT
POST {{host}}/api/actions
Content-Type: application/json

{
  "name": "TRANSLATE_TEXT",
  "description": "Translates formatted_text to customer language",
  "config": { "textField": "formatted_text", "languageField": "lang" }
}

### Action 4: SEND_EMAIL
POST {{host}}/api/actions
Content-Type: application/json

{
  "name": "SEND_EMAIL",
  "description": "Sends the translated text as an email via Ethereal",
  "config": { "toField": "email", "subjectField": "subject", "bodyField": "translated_text" }
}

### Update action config (Example 1)
PUT {{host}}/api/actions/9e9baf6f-bcf7-4428-b2c7-250027482c5f
Content-Type: application/json

{
  "config": {
    "arrayField": "items",
    "priceField": "price",
    "quantityField": "quantity"
  }
}

### Update action config (Example 2)
PUT {{host}}/api/actions/f2d8b728-ce46-443d-a815-f175c2599b2d
Content-Type: application/json

{
  "config": {
    "textField": "formatted_text",
    "languageField": "lang",
    "subjectField": "subject"
  }
}

### Update action config (Example 3)
PUT {{host}}/api/actions/47f6ecf5-4e64-426f-b25b-504b3d3f0c68
Content-Type: application/json

{
  "config": {
    "toField": "email",
    "subjectField": "translated_subject",
    "bodyField": "translated_text"
  }
}

### Update Action 2: TEXT_TEMPLATER (fixed template with @ldelim/@rdelim)
PUT {{host}}/api/actions/80316db3-b39f-4f46-a130-595d6a26c722
Content-Type: application/json

{
  "config": { "template": "Hello {{ldelim}}customer{{rdelim}}!\n\nThank you for choosing {{ldelim}}store_name{{rdelim}}. This is a summary of your purchase made on {{ldelim}}date{{rdelim}}:\n\n{{ldelim}}items{{rdelim}}\n\nSubtotal: ${{ldelim}}subtotal{{rdelim}}\nTotal paid: ${{ldelim}}total_amount{{rdelim}}\n\nCurrent status of your order: {{ldelim}}status{{rdelim}}\n\nWe hope to see you soon!" }
}

### Delete action by id
DELETE {{host}}/api/actions/87cdfa09-81e8-4521-b24e-155a05d9fd74


# ──────────────────────────────────────────────────────────────────────────────
# ─── PIPELINES ────────────────────────────────────────────────────────────────
# ──────────────────────────────────────────────────────────────────────────────

### Get all pipelines
GET {{host}}/api/pipelines

### Get pipeline by id
GET {{host}}/api/pipelines/bf8ccd92-763b-4cb1-a38d-b21248a1a59f

### Create pipeline 1 (Calculate)
POST {{host}}/api/pipelines
Content-Type: application/json

{
  "name": "Calculate total amount",
  "userId": "9c83aeee-4f10-4538-a55a-b7053b7bf0a2",
  "actionId": "9e9baf6f-bcf7-4428-b2c7-250027482c5f"
}

### Create pipeline 2 (Template)
POST {{host}}/api/pipelines
Content-Type: application/json

{
  "name": "Create text template",
  "userId": "9c83aeee-4f10-4538-a55a-b7053b7bf0a2",
  "actionId": "80316db3-b39f-4f46-a130-595d6a26c722"
}

### Create pipeline 3 (Translate)
POST {{host}}/api/pipelines
Content-Type: application/json

{
  "name": "Translate text message",
  "userId": "9c83aeee-4f10-4538-a55a-b7053b7bf0a2",
  "actionId": "f2d8b728-ce46-443d-a815-f175c2599b2d"
}

### Create pipeline 4 (Email)
POST {{host}}/api/pipelines
Content-Type: application/json

{
  "name": "Send email to customer",
  "userId": "9c83aeee-4f10-4538-a55a-b7053b7bf0a2",
  "actionId": "47f6ecf5-4e64-426f-b25b-504b3d3f0c68"
}

### Edit pipeline by id
PUT {{host}}/api/pipelines/da8bc89a-85b1-48e5-a44e-44afe36b4846
Content-Type: application/json

{
  "name": "My updated pipeline",
  "active": false
}

### Delete pipeline by id
DELETE {{host}}/api/pipelines/04df5936-4b81-414e-a3b3-f640c17aafad


# ──────────────────────────────────────────────────────────────────────────────
# ─── SUBSCRIBERS ──────────────────────────────────────────────────────────────
# ──────────────────────────────────────────────────────────────────────────────

### Get all subscribers
GET {{host}}/api/subscribers

### Get subscribers by pipeline id
GET {{host}}/api/subscribers/pipeline/33bdc773-5f6a-4a76-8b89-77262579ebda

### 1. Pipeline 1 (Calculate) -> points to Pipeline 2 (Template)
POST {{host}}/api/subscribers
Content-Type: application/json

{
  "pipelineId": "9ccaa884-91f0-482f-a05e-5293810badd1",
  "url": "{{host}}/api/webhooks/674b821f-086e-4e47-a955-936e18662654"
}

### 2. Pipeline 2 (Template) -> points to Pipeline 3 (Translate)
POST {{host}}/api/subscribers
Content-Type: application/json

{
  "pipelineId": "f065e32e-0f05-48ad-bf69-98189653a32d",
  "url": "{{host}}/api/webhooks/e5cc6c39-734b-4dd0-96d6-2da58996c04c"
}

### 3. Pipeline 3 (Translate) -> points to Pipeline 4 (Email)
POST {{host}}/api/subscribers
Content-Type: application/json

{
  "pipelineId": "140bd2dc-6d76-45a2-99fa-9bd0c7d55dbd",
  "url": "{{host}}/api/webhooks/ea959a1c-9432-46ad-9572-c2fd8f7b6fea"
}

### 4. Pipeline 4 (Email) -> Final destination
POST {{host}}/api/subscribers
Content-Type: application/json

{
  "pipelineId": "66c69421-bc23-4540-a791-7af308c6aba1",
  "url": "https://webhook.site/eb208e66-651f-40e2-96eb-4003dfbbbcf1" 
}

### Edit subscriber by id
PUT {{host}}/api/subscribers/427ffbee-ee71-434e-9a90-453da9d390b4
Content-Type: application/json

{
  "active": false
}

### Delete subscriber by id
DELETE {{host}}/api/subscribers/4b8f0eae-70de-4db3-be73-5e275347af59


# ──────────────────────────────────────────────────────────────────────────────
# ─── JOBS & DELIVERIES ────────────────────────────────────────────────────────
# ──────────────────────────────────────────────────────────────────────────────

### Get all jobs
GET {{host}}/api/jobs

### Get jobs by pipeline id
GET {{host}}/api/jobs?pipelineId=04df5936-4b81-414e-a3b3-f640c17aafad

### Get delivery attempts by job id
GET {{host}}/api/jobs/e12ca810-6898-4c62-85d7-6735a5e38f44/deliveries


# ──────────────────────────────────────────────────────────────────────────────
# ─── WORKFLOW TRIGGER (TEST CASES) ────────────────────────────────────────────
# ──────────────────────────────────────────────────────────────────────────────

### Test Full Chain: Success with Translation (Target Language: Portuguese)
POST {{host}}/api/webhooks/dd777e4f-5236-464d-8a20-387143798446
Content-Type: application/json

{
  "customer": "Anton",
  "email": "anton.yak12@yamail.com",
  "lang": "pt",
  "store_name": "Ruta Austral",
  "date": "2026-05-27",
  "status": "Shipping",
  "subject": "Order Confirmation",
  "items": [
    { "name": "Café Tueste Medio 250g", "quantity": 12, "price": 8500 },
    { "name": "Filtros de papel V60", "quantity": 2, "price": 4500 }
  ]
}

### Test Error handling (malformed JSON: missing closing quote for "customer")
POST {{host}}/api/webhooks/dd777e4f-5236-464d-8a20-387143798446
Content-Type: application/json

{
  "customer: "Anton",
  "email": "anton.yak12@yamail.com",
  "lang": "en",
  "store_name": "Ruta Austral",
  "date": "2026-05-27",
  "status": "En proceso de envío",
  "items": [
    { "name": "Café Tueste Medio 250g", "quantity": 12, "price": 8500 },
    { "name": "Filtros de papel V60", "quantity": 2, "price": 4500 }
  ]
}

### Test Error handling (missing 'store_name', 'date', 'status' fields)
POST {{host}}/api/webhooks/dd777e4f-5236-464d-8a20-387143798446
Content-Type: application/json

{
  "customer": "Anton",
  "email": "anton.yak12@yamail.com",
  "lang": "en",
  "items": []
}

### Test Error handling (missing 'email' field, empty items)
POST {{host}}/api/webhooks/dd777e4f-5236-464d-8a20-387143798446
Content-Type: application/json

{
  "customer": "Yareli",
  "lang": "en",
  "store_name": "Ruta Austral",
  "date": "2026-05-27",
  "status": "En proceso de envío",
  "items": []
}


# ──────────────────────────────────────────────────────────────────────────────
# ─── EXTRA EDGE CASES: VALIDATIONS & RETRY LOGIC ──────────────────────────────
# ──────────────────────────────────────────────────────────────────────────────

### Case 1: Fatal Error in CALCULATE_TOTAL (Empty items array)
### Expected: Pipeline throws "ValidationError". Worker aborts retries
### immediately and the Job ends in 'failed' (Attempt 1/3 only).
POST {{host}}/api/webhooks/dd777e4f-5236-464d-8a20-387143798446
Content-Type: application/json

{
  "customer": "Mob",
  "email": "mob.psycho@example.com",
  "lang": "es",
  "store_name": "Spirits & Such Consultation",
  "items": []
}

### Case 2: Fatal Error in CALCULATE_TOTAL (Item without price)
### Expected: Throws "ValidationError" at the item index. Aborts retries.
POST {{host}}/api/webhooks/dd777e4f-5236-464d-8a20-387143798446
Content-Type: application/json

{
  "customer": "Reigen Arataka",
  "email": "reigen@example.com",
  "lang": "es",
  "store_name": "Spirits & Such Consultation",
  "items": [
    { "name": "Low-level exorcism", "quantity": 1, "price": 5000 },
    { "name": "Shoulder massage with salt", "quantity": 2 } 
  ]
}

### Case 3: Success with Fallbacks in TEXT_TEMPLATER (Missing business fields)
### Expected: Pipeline finishes SUCCESSFULLY. Does not break due to empty fields;
### the email will be sent using default values ("Our Store", today's date, etc.)
### Language: German ("de")
POST {{host}}/api/webhooks/dd777e4f-5236-464d-8a20-387143798446
Content-Type: application/json

{
  "customer": "Hans",
  "email": "hans.v60@example.com",
  "lang": "de",
  "items": [
    { "name": "Kenia Specialty Coffee", "quantity": 1, "price": 9200 }
  ]
}

### Case 4: Successful Bypass in TRANSLATE_TEXT (Target Language: English)
### Expected: Detects "lang": "en" and interrupts the flow to MyMemory API.
### Avoids the "SAME_LANGUAGES" error and processes everything in a single, instant attempt.
POST {{host}}/api/webhooks/dd777e4f-5236-464d-8a20-387143798446
Content-Type: application/json

{
  "customer": "Spike Spiegel",
  "email": "spike@bebop.space",
  "lang": "en",
  "store_name": "Ruta Austral Store",
  "date": "2026-05-28",
  "status": "In transit",
  "subject": "Space Delivery Update",
  "items": [
    { "name": "Bell peppers and beef (No beef)", "quantity": 1, "price": 1200 }
  ]
}

### Case 5: Fatal Error in SEND_EMAIL (No email property in the payload)
### Expected: Actions 1, 2, and 3 succeed. Upon reaching SEND_EMAIL it throws
### "ValidationError: The email field..." and stops dead without useless retries.
POST {{host}}/api/webhooks/dd777e4f-5236-464d-8a20-387143798446
Content-Type: application/json

{
  "customer": "Faye Valentine",
  "lang": "fr",
  "store_name": "Bebop Commerce",
  "items": [
    { "name": "Kalita Wave filters", "quantity": 3, "price": 6000 }
  ]
}

### Case 6: Simulation of Temporary Error (External Translation API Down/Invalid)
### Expected: Send a language pair that breaks the API or an invalid code ("xyz").
### If your `fetchTranslation` sub-function throws a common error (not a ValidationError),
### you will see in your console how the job changes to 'pending' and retries every 10 seconds
### until exhausting the 3 attempts in your WSL terminal.
POST {{host}}/api/webhooks/dd777e4f-5236-464d-8a20-387143798446
Content-Type: application/json

{
  "customer": "Jet Black",
  "email": "jet.mechanic@example.com",
  "lang": "xyz",
  "store_name": "Ruta Austral",
  "items": [
    { "name": "Ship spare parts", "quantity": 1, "price": 45000 }
  ]
}